{
  "name": "GrafanaCon 2026 - AI Workshop",
  "hostRequirements": {
    "cpus": 8,
    "memory": "8gb",
    "storage": "32gb"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "-anthropic.claude-code"
      ],
      "settings": {
        "git.autofetch": false,
        "git.suggestSmartCommit": false,
        "chat.commandCenter.enabled": false,
        "chat.editor.enabled": false
      }
    }
  },
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Grafana",
      "onAutoForward": "openBrowserOnce"
    }
  },
  "otherPortsAttributes": {
    "onAutoForward": "silent"
  },
  "postCreateCommand": "curl -fsSL https://claude.ai/install.sh | bash"
}
